{
  "configurations": [
{%- if cookiecutter.project_cli %}
    {
      "cwd": "${workspaceFolder}",
      "name": "Debug program",
      "program": "${workspaceFolder}/build/Debug/{{ cookiecutter.__project_package }}",
      "preLaunchTask": "build_debug",
      "request": "launch",
      "type": "lldb"
    },
{%- endif %}
    {
      "cwd": "${workspaceFolder}",
      "name": "Debug tests",
      "program": "${workspaceFolder}/build/Test/test",
      "preLaunchTask": "build_test",
      "request": "launch",
      "type": "lldb"
    }
  ],
  "version": "0.2.0"
}
